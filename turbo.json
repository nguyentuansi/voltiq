{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".svelte-kit/**", "build/**", "dist/**", "target/release/**"]
    },
    "lint": {},
    "check": { "dependsOn": ["^build"] },
    "test": {}
  }
}
